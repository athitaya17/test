# PostgreSQL Configuration - Using airflow user consistently
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=datapipeline
POSTGRES_HOST=postgres
POSTGRES_PORT=5433

# Airflow Configuration
AIRFLOW_IMAGE_NAME=apache/airflow:2.9.1
AIRFLOW_UID=50000

# Python dependencies - installed at container startup
_PIP_ADDITIONAL_REQUIREMENTS=geopandas==1.0.1 shapely==2.0.6 pyproj==3.7.0 netCDF4==1.7.2 numpy==1.26.4 psycopg2-binary==2.9.9 rasterio==1.3.10